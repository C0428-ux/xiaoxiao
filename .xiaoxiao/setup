#!/bin/bash
# xiaoxiao 安装脚本
# 用法: bash setup

set -e

echo "🔧 安装 xiaoxiao..."

# 1. 克隆仓库（如需要）
if [ -d ~/.claude/skills/xiaoxiao ]; then
    echo "📁 xiaoxiao 已存在，更新中..."
    cd ~/.claude/skills/xiaoxiao
    git pull origin main
else
    echo "📥 克隆 xiaoxiao..."
    git clone https://github.com/C0428-ux/xiaoxiao.git ~/.claude/skills/xiaoxiao
    cd ~/.claude/skills/xiaoxiao
fi

# 2. 追加配置到 ~/.claude/CLAUDE.md
echo "📝 更新配置..."
CLAUDE_CONTENT=$(cat <<'EOF'

# XiaoXiao 开发框架

XiaoXiao 是一个 AI Agent 开发框架，通过 7 个有序的 Skill 引导完成项目从概念到上线的完整流程。

## 核心原则

- **做少**：窄比宽好，YAGNI
- **做精**：完整做完，RED-GREEN-REFACTOR
- **有证据**：interest ≠ demand
- **用系统**：系统化调试
- **会收尾**：no half-done projects

## 开发流程

产品咨询 → 战略评审 → 架构师 → 界面设计 → 任务规划 → TDD开发 → 发布上线

## 使用方式

对 Claude 说 `/xiaoxiao` 开始开发流程。

## 框架位置

- 框架：~/.claude/skills/xiaoxiao/
- 状态文件：.xiaoxiao/state.json
- 项目规格：.SPEC.md

EOF

# 检查是否已追加
if grep -q "XiaoXiao 开发框架" ~/.claude/CLAUDE.md 2>/dev/null; then
    echo "✅ 配置已存在，跳过"
else
    echo "$CLAUDE_CONTENT" >> ~/.claude/CLAUDE.md
    echo "✅ 配置已追加到 ~/.claude/CLAUDE.md"
fi

# 3. 验证
echo ""
echo "✅ xiaoxiao 安装完成！"
echo ""
echo "使用方式："
echo "  /xiaoxiao          - 开始开发流程"
echo "  /xiao             - 同上（简写）"
echo ""
echo "或手动运行："
echo "  node ~/.claude/skills/xiaoxiao/xiaoxiao.js start"
echo "  node ~/.claude/skills/xiaoxiao/xiaoxiao.js status"