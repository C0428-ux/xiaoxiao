{
  "skill": "product-consult",
  "description": "产品咨询，明确需求",
  "phases": [
    {
      "id": "phase1",
      "name": "Product Type & Core Scenario",
      "entry": { "command": "save-progress", "args": ["product-consult", "phase1-start"] },
      "actions": [
        "Ask product type",
        "Ask primary users",
        "Ask core scenario",
        "Ask single most important action",
        "Confirm summary with user"
      ],
      "exit": { "command": "save-progress", "args": ["product-consult", "phase1"] },
      "requiresConfirm": true
    },
    {
      "id": "phase2",
      "name": "Feature Design",
      "entry": { "command": "save-progress", "args": ["product-consult", "phase2-start"] },
      "actions": [
        "Ask essential features (P0)",
        "Ask important but not critical (P1)",
        "Ask nice to have (P2)",
        "Define primary user flow for each P0",
        "Ask what product should ABSOLUTELY NOT do"
      ],
      "exit": { "command": "save-progress", "args": ["product-consult", "phase2"] },
      "requiresConfirm": true
    },
    {
      "id": "phase3",
      "name": "User Experience Outline",
      "entry": { "command": "save-progress", "args": ["product-consult", "phase3-start"] },
      "actions": [
        "Ask navigation between features",
        "Ask main dashboard/home layout",
        "Ask how to access P0 features",
        "Outline key screens",
        "Ask about user roles"
      ],
      "exit": { "command": "save-progress", "args": ["product-consult", "phase3"] },
      "requiresConfirm": true
    },
    {
      "id": "phase4",
      "name": "Success Criteria",
      "entry": { "command": "save-progress", "args": ["product-consult", "phase4-start"] },
      "actions": [
        "Ask how to measure success",
        "Define measurable criteria",
        "Confirm criteria with user"
      ],
      "exit": { "command": "save-progress", "args": ["product-consult", "phase4"] },
      "requiresConfirm": true
    },
    {
      "id": "phase5",
      "name": "MVP Scope",
      "entry": { "command": "save-progress", "args": ["product-consult", "phase5-start"] },
      "actions": [
        "Ask absolute minimum for launch",
        "Define explicit boundaries",
        "State what's NOT in scope",
        "Confirm MVP scope"
      ],
      "exit": { "command": "save-progress", "args": ["product-consult", "phase5"] },
      "requiresConfirm": true
    },
    {
      "id": "phase6",
      "name": "Output SPEC.md",
      "entry": { "command": "save-progress", "args": ["product-consult", "phase6-start"] },
      "actions": [
        "Write .SPEC.md document",
        "Review with user",
        "Final CONFIRM before completion"
      ],
      "exit": { "command": "save-progress", "args": ["product-consult", "phase6"] },
      "requiresConfirm": true
    }
  ],
  "final": {
    "command": "complete",
    "args": ["product-consult", ".SPEC.md"]
  }
}
