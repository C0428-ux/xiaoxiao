{
  "skill": "architect",
  "description": "架构设计",
  "phases": [
    {
      "id": "phase1",
      "name": "Requirements Extraction",
      "entry": { "command": "save-progress", "args": ["architect", "phase1-start"] },
      "actions": [
        "Read SPEC.md",
        "Read strategy-review-output.md",
        "Identify non-functional requirements",
        "Ask top 3 technical constraints"
      ],
      "exit": { "command": "save-progress", "args": ["architect", "phase1"] },
      "requiresConfirm": true
    },
    {
      "id": "phase2",
      "name": "Architecture Pattern Selection",
      "entry": { "command": "save-progress", "args": ["architect", "phase2-start"] },
      "actions": [
        "Evaluate architectural patterns",
        "Ask which pattern fits best",
        "Document trade-off rationale"
      ],
      "exit": { "command": "save-progress", "args": ["architect", "phase2"] },
      "requiresConfirm": true
    },
    {
      "id": "phase3",
      "name": "Subsystem Decomposition",
      "entry": { "command": "save-progress", "args": ["architect", "phase3-start"] },
      "actions": [
        "Identify bounded contexts",
        "Define subsystems",
        "Document responsibilities",
        "Identify cross-cutting concerns"
      ],
      "exit": { "command": "save-progress", "args": ["architect", "phase3"] },
      "requiresConfirm": true
    },
    {
      "id": "phase4",
      "name": "Interface & Data Flow Design",
      "entry": { "command": "save-progress", "args": ["architect", "phase4-start"] },
      "actions": [
        "Define interfaces between subsystems",
        "Specify API contracts",
        "Design data flow",
        "Document error handling"
      ],
      "exit": { "command": "save-progress", "args": ["architect", "phase4"] },
      "requiresConfirm": true
    },
    {
      "id": "phase5",
      "name": "Technology Decisions",
      "entry": { "command": "save-progress", "args": ["architect", "phase5-start"] },
      "actions": [
        "Make key technology choices",
        "Create ADRs",
        "Ask rollback plan"
      ],
      "exit": { "command": "save-progress", "args": ["architect", "phase5"] },
      "requiresConfirm": true
    },
    {
      "id": "phase6",
      "name": "Architecture Documentation",
      "entry": { "command": "save-progress", "args": ["architect", "phase6-start"] },
      "actions": [
        "Create architecture diagram",
        "Document all ADRs",
        "Create data flow diagram",
        "Review with user",
        "Final CONFIRM before completion"
      ],
      "exit": { "command": "save-progress", "args": ["architect", "phase6"] },
      "requiresConfirm": true
    }
  ],
  "final": {
    "command": "complete",
    "args": ["architect", "docs/xiaoxiao/plans/architect-output.md"]
  }
}
